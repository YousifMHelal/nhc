# Copy this file to .env and fill in the values.
# Without DATABASE_URL the app runs fully on mock data (demo mode).

# Option A — Docker (local dev, port 5433 to avoid system Postgres conflict)
# docker compose up -d postgres
# DATABASE_URL="postgresql://nhc:nhcdev@localhost:5433/nhc_crm"

# Option B — Neon (production/staging)
# Get your connection string at: https://console.neon.tech
# DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"
